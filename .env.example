# ================= WalletForge — configuration =================
PORT=3000
BASE_URL=https://ton-domaine.com          # URL publique (obligatoire pour QR + Apple web service)
DATABASE_URL=postgres://user:pass@localhost:5432/walletforge
JWT_SECRET=change-moi-en-prod-64-chars-aleatoires

# ---------- Stripe ----------
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_START=price_xxx
STRIPE_PRICE_GROW=price_xxx
STRIPE_PRICE_BUSINESS=price_xxx

# ---------- Apple Wallet (à remplir quand tu as ta licence Apple Developer, 99$/an) ----------
# 1. Sur developer.apple.com : Certificates > Identifiers > créer un "Pass Type ID" (ex: pass.com.tondomaine.loyalty)
# 2. Générer le certificat du Pass Type ID, l'exporter en .p12 depuis Keychain
# 3. Convertir :  openssl pkcs12 -in cert.p12 -clcerts -nokeys -out certs/apple-cert.pem -legacy
#                 openssl pkcs12 -in cert.p12 -nocerts -nodes -out certs/apple-key.pem -legacy
# 4. Télécharger le WWDR G4 : https://www.apple.com/certificateauthority/ -> certs/apple-wwdr.pem
APPLE_PASS_TYPE_ID=pass.com.tondomaine.loyalty
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_CERT_PATH=certs/apple-cert.pem
APPLE_KEY_PATH=certs/apple-key.pem
APPLE_KEY_PASSPHRASE=
APPLE_WWDR_PATH=certs/apple-wwdr.pem

# ---------- APNs (notifications de mise à jour des passes Apple) ----------
# Clé APNs (.p8) : developer.apple.com > Keys > créer une clé avec APNs activé
APNS_KEY_PATH=certs/apns-key.p8
APNS_KEY_ID=XXXXXXXXXX
# Le Team ID sert aussi pour APNs

# ---------- Google Wallet ----------
# 1. https://pay.google.com/business/console -> créer un compte émetteur (Issuer ID)
# 2. GCP : créer un service account avec le rôle Wallet Object Issuer, télécharger la clé JSON
GOOGLE_WALLET_ISSUER_ID=3388000000000000000
GOOGLE_SERVICE_ACCOUNT_JSON=certs/google-service-account.json
